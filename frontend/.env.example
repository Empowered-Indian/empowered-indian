# Environment Configuration for Empowered Indian Frontend
# Copy this to .env and update the values as needed

# App Configuration
VITE_APP_NAME="Empowered Indian MPLADS Dashboard"
VITE_APP_VERSION="1.0.0"

# API Configuration
# Prefer using a single base URL in most code paths
VITE_API_URL=http://localhost:8080/api
# Optional explicit overrides per environment if needed by code
VITE_API_URL_DEVELOPMENT=http://localhost:8080/api
VITE_API_URL_PRODUCTION=https://your-production-domain.com/api

# Analytics Configuration
VITE_GA_TRACKING_ID=your_ga_tracking_id_here

# Feature Flags
VITE_ENABLE_ANALYTICS=true

# Development Settings
VITE_DEBUG_MODE=true
